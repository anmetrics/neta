{
  "name": "@anmetric/neta",
  "version": "1.9.9",
  "description": "Tiny, elegant HTTP client built on fetch for browser and Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/anmetrics/neta.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:edge-cases": "vitest run test/edge-cases.test.ts",
    "test:memory": "vitest run test/memory-leak.test.ts",
    "benchmark": "node test/benchmark.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
